{
  "manifest_version": 4,
  "type": "background_app",
  "name": "TFT Companion PoC",
  "author": "TFT Companion",
  "version": "0.0.1",
  "game_id": 21570,
  "game_events": [21570],
  "permissions": {
    "game_info": true,
    "websocket": true
  },
  "background_apps": {
    "tft-companion-poc-bridge": {
      "start_page": "background-bridge.html",
      "activate_on_events": ["GameInfoUpdated"]
    }
  },
  "windows": {
    "renderer": {
