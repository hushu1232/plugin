      "transparent": true,
      "resizable": false,
      "show_in_taskbar": false,
      "disable_window_resize": true,
      "topmost": true,
      "clickthrough": true,
      "force_capture_on_focus": false,
      "show_minimize": false,
      "show_maximize": false
    }
  }
}
